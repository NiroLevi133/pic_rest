# Database
DATABASE_URL=postgresql://user:password@host:5432/restorante

# Encryption
SETTINGS_ENCRYPTION_KEY=your-32-char-secret-key-here!!

# AI Providers (optional — can also be set via /api/settings)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Background generation
LAMBDA_GENERATE_URL=
APP_URL=https://your-backend-url.vercel.app
BG_SECRET=your-bg-secret-here

# CORS — allow requests from your mobile app
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
